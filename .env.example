# Windows Docker Desktop 请使用正斜杠路径。
# 不要给 .env 中的路径额外加引号。

CLOUDDRIVE_MOUNT_PATH=C:/CloudDrive
LOCAL_MEDIA_PATH=/vol1/1000/media
REFERENCE_STRM_PATH=/vol1/1000/media/小姐姐
APP_PORT=8080

SCAN_BATCH_SIZE=250
SCAN_WORKERS=2

READ_ONLY_MODE=true
ENABLE_REMOTE_WRITE=false
ENABLE_EXTERNAL_METADATA=false
ENABLE_REAL_MOVE=false
ENABLE_AI_TRANSLATION=false
CMS_SYNC_URL=http://10.10.10.112:9527/api/sync/lift_by_token?type=lift_sync&token=cloud_media_sync
CMS_SYNC_TIMEOUT_SECONDS=30

AI_TRANSLATION_API_KEY=
AI_TRANSLATION_BASE_URL=https://api.openai.com/v1
AI_TRANSLATION_MODEL=gpt-4.1-mini
TRANSLATION_MONITOR_INTERVAL_SECONDS=60
TRANSLATION_MONITOR_MAX_JOBS_PER_SCAN=20

CLOUDDRIVE_BIND_READ_ONLY=true
LOCAL_MEDIA_BIND_READ_ONLY=true
REFERENCE_STRM_BIND_READ_ONLY=true

ALLOWED_TRANSLATION_ROOTS=/mnt/local-media,/mnt/reference-strm,/mnt/clouddrive
